meta {
  name: 5 - Update Task
  type: http
  seq: 5
}

put {
  url: {{baseUrl}}/api/tasks/{{taskId}}
  body: json
  auth: none
}

headers {
  Accept: application/json
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "priority": "alta"
  }
}

tests {
  test("status is 200", function () {
    expect(res.getStatus()).to.equal(200);
  });
  test("priority was updated", function () {
    expect(res.body.data.priority).to.equal("alta");
  });
}
